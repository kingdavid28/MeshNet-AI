{
  "name": "meshnet-desktop",
  "version": "1.0.0",
  "description": "MeshNet Desktop Application with native WiFi capabilities",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dev": "electron . --dev"
  },
  "keywords": ["meshnet", "wifi", "p2p"],
  "author": "MeshNet",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "node-wifi-scanner": "^1.0.0",
    "bonjour": "^3.5.0",
    "selfsigned": "^2.4.1"
  },
  "build": {
    "appId": "com.meshnet.desktop",
    "productName": "MeshNet",
    "win": {
      "target": "dir",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "files": [
      "main.js",
      "preload.js",
      "wifi-module/**/*"
    ]
  }
}
