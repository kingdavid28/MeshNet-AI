# MeshNet AI — Backend environment variables
# Copy this file to config/.env and fill in real values before starting.
#
# Generate secrets:
#   MESH_SECRET / MESH_NODE_SECRET:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   or:
#     python -c "import secrets; print(secrets.token_hex(32))"

# ── Express server ────────────────────────────────────────────────────────────
PORT=4000

# Node identity (used in /api/health response and log traces)
NODE_ID=cmd-hq

# ── Layer 4: SQLite database ──────────────────────────────────────────────────
DB_PATH=../database/meshnet.db

# ── Layer 3: Python AI routing service ───────────────────────────────────────
PYTHON_ROUTER_URL=http://localhost:5050

# ── Auth (REQUIRED — server refuses to start without these) ──────────────────
# Shared secret sent by all mesh nodes in the X-Mesh-Secret HTTP header.
MESH_SECRET=change-me-to-a-long-random-secret

# Python layer HMAC / AES key derivation secret (must match MESH_SECRET or be separate)
MESH_NODE_SECRET=change-me-to-a-long-random-secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed request origins.
# For the Android WebView, add the capacitor:// scheme and your LAN IP.
# Example:  http://10.0.0.5:4000,capacitor://localhost,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── IBM Cloudant (server-side only — NEVER expose these to the frontend) ──────
# The frontend calls GET /api/cloudant/nodes; the backend proxies to Cloudant.
CLOUDANT_URL=https://<your-instance>.cloudantnosqldb.appdomain.cloud
CLOUDANT_API_KEY=<your-iam-api-key>
CLOUDANT_DB=mesh_nodes_db

# ── Supabase / PostgreSQL (optional) ─────────────────────────────────────────
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Layer 2: Python simulation tuning ────────────────────────────────────────
MESH_BLE_RANGE_FLOOD=80
MESH_BLE_RANGE_WAR_ZONE=20
MESH_BLE_RANGE_EARTHQUAKE=120
MESH_WIFI_RANGE_FLOOD=200
MESH_WIFI_RANGE_WAR_ZONE=50
MESH_WIFI_RANGE_EARTHQUAKE=400
MESH_TOTAL_NODES=100

# ── Stale-node eviction (optional overrides) ─────────────────────────────────
NODE_STALE_MS=180000     # 3 min — zero out signal/radios of silent nodes
NODE_EVICT_MS=600000     # 10 min — hard-delete nodes that haven't checked in
EVICT_INTERVAL_MS=30000  # 30 s — eviction job run interval
