# MeshNet AI — Frontend environment variables
# Copy this file to .env.local and fill in real values before running.

# Backend API base URL reachable from the device.
VITE_API_BASE_URL=http://localhost:4000

# Simulation mode — set to true to use the local mock simulation instead of the backend.
VITE_SIM_MODE=false
VITE_SIM_TICK_MS=5000

# Shared mesh secret (must match backend/config/.env MESH_SECRET).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_MESH_SECRET=change-me-to-a-long-random-secret

# Supabase (optional — leave blank to skip)
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>
